# Gemini OCR
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Auth — required in production
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google Sheets — required in production
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_FOLDER_ID=

# App
NEXT_PUBLIC_APP_NAME=Cowell OCR
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev only (never enable in production)
NEXT_PUBLIC_DEV_AUTO_LOGIN=false
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
