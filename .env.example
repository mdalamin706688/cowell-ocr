# Gemini OCR (production — set MOCK_OCR=false)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local FE demo — sample OCR data, no external API (100% free)
MOCK_OCR=false

# Auth — required in production (server cookie auth fallback)
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# AWS Cognito (email/password SPA login — preferred for CloudFront static FE)
NEXT_PUBLIC_COGNITO_REGION=ap-south-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=

# Google Sheets — FE OAuth (preferred: user connects Google from the browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Optional shared Drive folder (works with user OAuth or service account)
GOOGLE_SHEETS_FOLDER_ID=
NEXT_PUBLIC_GOOGLE_SHEETS_FOLDER_ID=

# Google Sheets — service account fallback (server-side; optional if FE OAuth is set)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# App
NEXT_PUBLIC_APP_NAME=Cowell OCR
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev only (never enable in production)
NEXT_PUBLIC_DEV_AUTO_LOGIN=false
NEXT_PUBLIC_DEV_LOGIN_EMAIL=
NEXT_PUBLIC_DEV_LOGIN_PASSWORD=
